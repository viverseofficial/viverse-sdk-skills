{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skills Catalog",
  "type": "object",
  "required": ["version", "skills"],
  "properties": {
    "version": { "type": "string" },
    "generated_at": { "type": "string" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    }
  }
}
