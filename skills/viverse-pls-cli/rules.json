{
  "rules": [
    {
      "id": "pls-cli-no-inline-credentials",
      "profiles": ["upload", "replace"],
      "phases": ["upload", "replace", "verify", "fix"],
      "type": "forbidden_any",
      "pattern": "--email=['\"]?[^$\\s]{1,}['\"]?|--password=['\"]?[^$\\s]{1,}['\"]?",
      "message": "Never pass credentials as literal values in shell commands — use env vars ($PLS_CLI_TEST_EMAIL, $PLS_CLI_TEST_PASSWORD).",
      "severity": "high"
    },
    {
      "id": "pls-cli-env-vars-sourced",
      "profiles": ["upload", "replace"],
      "phases": ["upload", "replace"],
      "type": "required_any",
      "pattern": "source .env|\\$PLS_CLI_TEST_EMAIL|\\$PLS_CLI_TEST_PASSWORD",
      "message": "Credentials must be loaded from env vars before running pls-cli commands.",
      "severity": "high"
    },
    {
      "id": "pls-cli-json-flag-for-agents",
      "profiles": ["upload", "replace"],
      "phases": ["upload", "replace"],
      "type": "required_any",
      "pattern": "--json",
      "message": "Always pass --json when parsing upload/replace output programmatically.",
      "severity": "medium"
    },
    {
      "id": "pls-cli-stage-consistency",
      "profiles": ["upload", "replace"],
      "phases": ["upload", "replace", "verify"],
      "type": "required_any",
      "pattern": "pls-cli login.*--stage|bin/pls-cli login.*--stage",
      "message": "When uploading with --stage, ensure login was also performed with --stage flag.",
      "severity": "high"
    },
  ]
}
