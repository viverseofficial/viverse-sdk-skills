# Lambda admin API credential (never commit real value)
LAMBDA_AUTHKEY=replace_with_lambda_authkey

# Target app scope for lambda env/script sync (recommended)
LAMBDA_GAME_ID=replace_with_real_app_id

# Required for places_search_event
GOOGLE_PLACES_API_KEY=replace_with_places_key

# Optional override for places endpoint
GOOGLE_PLACES_TEXT_SEARCH_URL=https://places.googleapis.com/v1/places:searchText

# Required for tiles_root_bootstrap_event
GOOGLE_TILES_API_KEY=replace_with_tiles_key

# Optional override for tiles root endpoint
GOOGLE_TILES_ROOT_URL=https://tile.googleapis.com/v1/3dtiles/root.json
